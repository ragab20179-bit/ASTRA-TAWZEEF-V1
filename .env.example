# ============================================================================
# ASTRA / TAWZEEF Production Environment Configuration
# ============================================================================
# Copy this file to .env and update values for your environment
# cp .env.example .env

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
PG_HOST=postgres
PG_PORT=5432
PG_DB=astra
PG_USER=astra
# IMPORTANT: Change this to a secure password in production!
PG_PASSWORD=CHANGE_ME_SECURE_PASSWORD
PG_CONNECT_TIMEOUT=2

# ============================================================================
# ASTRA CORE CONFIGURATION
# ============================================================================
ASTRA_PORT=8000
ASTRA_POLICY_PACK_PATH=/app/services/astra_core/policy_pack.json
# Timeout for policy pack loading (in seconds)
ASTRA_STARTUP_TIMEOUT=10

# ============================================================================
# ORCHESTRATOR CONFIGURATION
# ============================================================================
ORCHESTRATOR_PORT=8001
ASTRA_URL=http://astra-core:8000/v1/astra/authority/check
# Timeout for ASTRA calls (in seconds)
ASTRA_TIMEOUT_S=0.3

# ============================================================================
# WATCHER CONFIGURATION
# ============================================================================
WATCHER_PORT=8002
# Enable watcher service (true/false)
WATCHER_ENABLED=false

# ============================================================================
# METRICS CONFIGURATION (Optional)
# ============================================================================
# Leave empty to disable metrics
STATSD_HOST=
STATSD_PORT=8125

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=info
# Options: debug, info, warning, error, critical

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=production

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# API Key for authentication (if implemented)
API_KEY=

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
# Backup schedule (cron format)
BACKUP_SCHEDULE="0 2 * * *"
# Backup retention days
BACKUP_RETENTION_DAYS=30
